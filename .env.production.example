# ─── ZentraBite production env template ─────────────────────────────────────
# Copy into Vercel → Project → Settings → Environment Variables (Production).
# Mark everything "Production" (and Preview if you want PR previews to work).
# Anything NEXT_PUBLIC_* is exposed to the browser — never paste secrets there.

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...            # Supabase → Settings → API → anon public
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...                # Supabase → Settings → API → service_role (server only, keep secret)

# ─── App URLs ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://dashboard.zentrabite.com.au
NEXT_PUBLIC_MARKETING_URL=https://zentrabite.com.au
NEXT_PUBLIC_STOREFRONT_URL=https://shop.zentrabite.com.au   # used in customer receipts & share links

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...                          # Stripe → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...                        # Created when you add the webhook endpoint
STRIPE_PRICE_MERCHANT_MONTHLY=price_...                # Your live $99/mo Growth price ID

# ─── Twilio (SMS) ───────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+61...                             # Purchased AU number

# ─── Resend (email) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ZentraBite <orders@zentrabite.com.au>

# ─── Anthropic (marketing-site AI co-pilot) ─────────────────────────────────
# Powers /api/ai-chat, the streamed Q&A widget on the landing page.
# Set on the apps/web Vercel project only — never expose to the browser.
ANTHROPIC_API_KEY=sk-ant-api...

# ─── Cron ───────────────────────────────────────────────────────────────────
# Vercel passes this automatically in Authorization: Bearer <secret>
# Generate a long random string: `openssl rand -hex 32`
CRON_SECRET=change-me-to-a-long-random-string

# Public host for storefront subdomains (used in winback SMS/email links)
NEXT_PUBLIC_STOREFRONT_HOST=shop.zentrabite.com.au

# ─── Optional: delivery providers ───────────────────────────────────────────
# UBER_DIRECT_CLIENT_ID=...
# UBER_DIRECT_CLIENT_SECRET=...
# DOORDASH_DEVELOPER_ID=...
# DOORDASH_KEY_ID=...
# DOORDASH_SIGNING_SECRET=...
